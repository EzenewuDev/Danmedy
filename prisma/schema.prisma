generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Patient {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  email     String   @unique
  status    String   @default("active")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  patientId Int
  notes     String?
}
